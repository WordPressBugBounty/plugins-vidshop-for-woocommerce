#. Plugin Name of the plugin
#: vidshop-for-woocommerce.php
#: includes/admin/class-admin-loader.php:361
msgid "VidShop for WooCommerce"
msgstr "فيدشوب لووكومرس"

#. Description of the plugin
#: vidshop-for-woocommerce.php
msgid "Upload your own videos and display WooCommerce products inside them. Let users interact and add items to cart while watching. Lightweight, fast, and fully integrated with WooCommerce."
msgstr "ارفع مقاطع الفيديو الخاصة بك واعرض منتجات ووكومرس بداخلها. دع المستخدمين يتفاعلون ويضيفون المنتجات إلى السلة أثناء المشاهدة. خفيف وسريع ومتكامل بالكامل مع ووكومرس."

#. Author of the plugin
#: vidshop-for-woocommerce.php
msgid "WPCreatix"
msgstr "WPCreatix"

#. Plugin URI of the plugin
#. Author URI of the plugin
#: vidshop-for-woocommerce.php
msgid "https://wpcreatix.com/"
msgstr "https://wpcreatix.com/"

